# =============================================================================
# VLouvain environment variables
# Copy this file to .env and adjust values as needed.
# None of these are required — sensible defaults are provided.
# =============================================================================

# ── Algorithm ──────────────────────────────────────────────────────────────

# Default number of nearest neighbours for k-NN graph construction
VLOUVAIN_K=15

# Maximum label-propagation / Louvain iterations
VLOUVAIN_N_ITER=10

# Louvain resolution parameter (higher → more, smaller clusters)
VLOUVAIN_RESOLUTION=1.0

# Random seed for reproducibility
VLOUVAIN_RANDOM_STATE=42

# FAISS IVF nprobe (breadth of approximate search; higher = more accurate, slower)
# VLOUVAIN_NPROBE=10

# Threshold for switching from Louvain to label propagation
# Datasets with n > this value use fast LP; smaller datasets use full Louvain
VLOUVAIN_LOUVAIN_THRESHOLD=50000

# Threshold for switching to numpy-median mode inside LP (vs scipy.stats.mode)
VLOUVAIN_LP_THRESHOLD=200000

# ── Benchmark ──────────────────────────────────────────────────────────────

# Number of vectors for `vlouvain bench`
VLOUVAIN_BENCH_N=1000000

# Embedding dimensionality for synthetic benchmark data
VLOUVAIN_BENCH_DIM=32

# Number of ground-truth clusters in synthetic benchmark data
VLOUVAIN_BENCH_CLUSTERS=100

# Within-cluster noise std (lower = tighter, better-separated clusters)
VLOUVAIN_BENCH_STD=0.05

# ── KMeans baseline ────────────────────────────────────────────────────────

# MiniBatchKMeans batch size
VLOUVAIN_KMEANS_BATCH=10240

# ── HDBSCAN baseline ───────────────────────────────────────────────────────

# Minimum cluster size for HDBSCAN
VLOUVAIN_HDBSCAN_MIN_CLUSTER=50

# ── Package metadata ───────────────────────────────────────────────────────

# Repository URL shown in setup.py
# VLOUVAIN_REPO_URL=https://github.com/yourorg/vlouvain

# Author name shown in setup.py
# VLOUVAIN_AUTHOR=Your Name
